@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status" aria-live="polite">
    Current count: <strong>@CurrentCount</strong>
</p>

<div class="btn-group" role="group">
    <button class="btn btn-primary" @onclick="IncrementAsync">
        + Increment
    </button>

    <button class="btn btn-secondary" @onclick="DecrementAsync" disabled="@IsZero">
        - Decrement
    </button>

    <button class="btn btn-danger" @onclick="ResetAsync" disabled="@IsZero">
        Reset
    </button>
</div>

@code {
    private int CurrentCount { get; set; } = 0;

    private bool IsZero => CurrentCount == 0;

    private Task IncrementAsync()
    {
        CurrentCount++;
        return Task.CompletedTask;
    }

    private Task DecrementAsync()
    {
        if (CurrentCount > 0)
        {
            CurrentCount--;
        }

        return Task.CompletedTask;
    }

    private Task ResetAsync()
    {
        CurrentCount = 0;
        return Task.CompletedTask;
    }
}