@page "/whackamole"

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CYBER MOLE</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet" />
    <style>
        :root {
            --neon-cyan: #00f5ff;
            --neon-pink: #ff006e;
            --neon-yellow: #ffe600;
            --neon-green: #39ff14;
            --neon-purple: #bf00ff;
            --dark-bg: #05060f;
            --grid-bg: #0a0d1c;
            --panel-bg: #0d1028;
            --border-dim: #1a2040;
            --text-dim: #4a5580;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: var(--dark-bg);
            color: #e0e8ff;
            font-family: 'Share Tech Mono', monospace;
            min-height: 100vh;
            overflow-x: hidden;
        }

            /* ─── Scanline overlay ─── */
            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background: repeating-linear-gradient( 0deg, transparent, transparent 2px, rgba(0, 245, 255, 0.015) 2px, rgba(0, 245, 255, 0.015) 4px );
                pointer-events: none;
                z-index: 9999;
            }

            /* ─── Grid bg pattern ─── */
            body::after {
                content: '';
                position: fixed;
                inset: 0;
                background-image: linear-gradient(rgba(0,245,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(0,245,255,0.04) 1px, transparent 1px);
                background-size: 40px 40px;
                pointer-events: none;
                z-index: 0;
            }

        .wrapper {
            position: relative;
            z-index: 1;
            max-width: 1100px;
            margin: 0 auto;
            padding: 24px 16px 48px;
        }

        /* ─── Header ─── */
        .site-header {
            text-align: center;
            margin-bottom: 32px;
        }

            .site-header h1 {
                font-family: 'Orbitron', sans-serif;
                font-size: clamp(2rem, 6vw, 3.8rem);
                font-weight: 900;
                letter-spacing: 0.12em;
                text-transform: uppercase;
                color: var(--neon-cyan);
                text-shadow: 0 0 8px var(--neon-cyan), 0 0 24px var(--neon-cyan), 0 0 60px rgba(0,245,255,0.4);
                animation: flicker 6s infinite;
            }

            .site-header .subtitle {
                font-size: 0.75rem;
                letter-spacing: 0.3em;
                color: var(--neon-pink);
                text-shadow: 0 0 8px var(--neon-pink);
                margin-top: 6px;
                text-transform: uppercase;
            }

        @@keyframes flicker {
            0%, 93%, 95%, 97%, 100% {
                opacity: 1;
            }

            94%, 96% {
                opacity: 0.7;
            }
        }

        /* ─── Layout ─── */
        .layout {
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 24px;
            align-items: start;
        }
        @@media (max-width: 800px) {
            .layout {
                grid-template-columns: 1fr;
            }
        }

        /* ─── Panel ─── */
        .panel {
            background: var(--panel-bg);
            border: 1px solid var(--border-dim);
            border-radius: 4px;
            padding: 20px;
            position: relative;
        }

            .panel::before {
                content: '';
                position: absolute;
                inset: -1px;
                border-radius: 4px;
                background: linear-gradient(135deg, rgba(0,245,255,0.15), transparent 50%, rgba(255,0,110,0.1));
                z-index: -1;
            }

        .panel-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.65rem;
            letter-spacing: 0.25em;
            color: var(--neon-cyan);
            text-transform: uppercase;
            margin-bottom: 16px;
            border-bottom: 1px solid var(--border-dim);
            padding-bottom: 10px;
        }

        /* ─── HUD bar ─── */
        .hud {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .hud-item {
            flex: 1;
            min-width: 100px;
            background: var(--grid-bg);
            border: 1px solid var(--border-dim);
            border-radius: 4px;
            padding: 12px 16px;
            text-align: center;
        }

        .hud-label {
            font-size: 0.6rem;
            letter-spacing: 0.2em;
            color: var(--text-dim);
            text-transform: uppercase;
            display: block;
            margin-bottom: 4px;
        }

        .hud-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--neon-yellow);
            text-shadow: 0 0 10px var(--neon-yellow);
            line-height: 1;
        }

        #timer-val {
            color: var(--neon-pink);
            text-shadow: 0 0 10px var(--neon-pink);
        }

        #combo-val {
            color: var(--neon-green);
            text-shadow: 0 0 10px var(--neon-green);
        }

        /* ─── Game grid ─── */
        .game-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }
        @@media (max-width: 500px) {
            .game-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 8px;
            }
        }

        /* ─── Hole ─── */
        .hole {
            aspect-ratio: 1;
            background: radial-gradient(ellipse at 50% 80%, #050810 60%, #0a0f20 100%);
            border-radius: 50%;
            border: 2px solid var(--border-dim);
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: border-color 0.1s;
            box-shadow: inset 0 4px 20px rgba(0,0,0,0.8);
        }

            .hole:hover {
                border-color: rgba(0,245,255,0.3);
            }

        /* Mole face */
        .mole {
            position: absolute;
            bottom: -100%;
            left: 50%;
            transform: translateX(-50%);
            width: 70%;
            height: 70%;
            transition: bottom 0.12s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .hole.active .mole {
            bottom: 5%;
        }

        .hole.whacked .mole {
            bottom: -100%;
            transition: bottom 0.08s ease-in;
        }

        .mole-svg {
            width: 100%;
            height: 100%;
        }

        /* Ring glow when active */
        .hole.active {
            border-color: var(--neon-cyan);
            box-shadow: inset 0 4px 20px rgba(0,0,0,0.8), 0 0 12px rgba(0,245,255,0.3), 0 0 28px rgba(0,245,255,0.15);
        }

        .hole.bomb.active {
            border-color: var(--neon-pink);
            box-shadow: inset 0 4px 20px rgba(0,0,0,0.8), 0 0 12px rgba(255,0,110,0.4), 0 0 28px rgba(255,0,110,0.2);
        }

        /* ─── Hit effects ─── */
        .hit-flash {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0,245,255,0.6) 0%, transparent 70%);
            opacity: 0;
            pointer-events: none;
            animation: hitFlash 0.35s ease-out forwards;
        }

        .bomb-flash {
            background: radial-gradient(circle, rgba(255,0,110,0.7) 0%, transparent 70%);
        }
        @@keyframes hitFlash {
            0% {
                opacity: 1;
                transform: scale(0.5);
            }

            100% {
                opacity: 0;
                transform: scale(1.6);
            }
        }

        /* Floating score text */
        .score-pop {
            position: fixed;
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            font-size: 1.2rem;
            pointer-events: none;
            animation: scorePop 0.9s ease-out forwards;
            z-index: 1000;
            text-shadow: 0 0 8px currentColor;
        }
        @@keyframes scorePop {
            0% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }

            100% {
                opacity: 0;
                transform: translateY(-80px) scale(1.4);
            }
        }

        /* ─── Controls ─── */
        .controls {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn {
            flex: 1;
            min-width: 100px;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 12px 20px;
            border-radius: 2px;
            cursor: pointer;
            border: 1px solid;
            background: transparent;
            transition: all 0.15s;
            position: relative;
            overflow: hidden;
        }

            .btn::before {
                content: '';
                position: absolute;
                inset: 0;
                opacity: 0;
                transition: opacity 0.15s;
            }

            .btn:hover::before {
                opacity: 1;
            }

            .btn:active {
                transform: scale(0.97);
            }

        .btn-start {
            color: var(--neon-cyan);
            border-color: var(--neon-cyan);
            text-shadow: 0 0 8px var(--neon-cyan);
            box-shadow: 0 0 12px rgba(0,245,255,0.2), inset 0 0 12px rgba(0,245,255,0.05);
        }

            .btn-start::before {
                background: rgba(0,245,255,0.1);
            }

            .btn-start:hover {
                box-shadow: 0 0 20px rgba(0,245,255,0.4), inset 0 0 20px rgba(0,245,255,0.1);
            }

        .btn-stop {
            color: var(--neon-pink);
            border-color: var(--neon-pink);
            text-shadow: 0 0 8px var(--neon-pink);
            box-shadow: 0 0 12px rgba(255,0,110,0.2), inset 0 0 12px rgba(255,0,110,0.05);
        }

            .btn-stop::before {
                background: rgba(255,0,110,0.1);
            }

            .btn-stop:hover {
                box-shadow: 0 0 20px rgba(255,0,110,0.4), inset 0 0 20px rgba(255,0,110,0.1);
            }

        /* ─── Difficulty ─── */
        .diff-group {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }

        .diff-btn {
            flex: 1;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.55rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 8px;
            border-radius: 2px;
            cursor: pointer;
            border: 1px solid var(--border-dim);
            background: transparent;
            color: var(--text-dim);
            transition: all 0.15s;
        }

            .diff-btn.active-diff, .diff-btn:hover {
                border-color: var(--neon-purple);
                color: var(--neon-purple);
                text-shadow: 0 0 6px var(--neon-purple);
                box-shadow: 0 0 8px rgba(191,0,255,0.2);
            }

        /* ─── Overlay / modal ─── */
        .overlay {
            position: absolute;
            inset: 0;
            background: rgba(5,6,15,0.9);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            z-index: 10;
            text-align: center;
            padding: 24px;
            backdrop-filter: blur(2px);
        }

            .overlay.hidden {
                display: none;
            }

        .overlay-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.8rem;
            font-weight: 900;
            color: var(--neon-yellow);
            text-shadow: 0 0 16px var(--neon-yellow);
            letter-spacing: 0.1em;
            margin-bottom: 8px;
        }

        .overlay-sub {
            font-size: 0.8rem;
            color: var(--text-dim);
            margin-bottom: 24px;
            letter-spacing: 0.1em;
        }

        .final-score {
            font-family: 'Orbitron', sans-serif;
            font-size: 3rem;
            font-weight: 900;
            color: var(--neon-cyan);
            text-shadow: 0 0 20px var(--neon-cyan);
            margin-bottom: 6px;
        }

        .final-label {
            font-size: 0.6rem;
            letter-spacing: 0.25em;
            color: var(--text-dim);
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        /* Name input */
        .name-row {
            display: flex;
            gap: 8px;
            width: 100%;
            max-width: 340px;
            margin-bottom: 16px;
        }

        .name-input {
            flex: 1;
            background: var(--grid-bg);
            border: 1px solid var(--neon-cyan);
            color: var(--neon-cyan);
            font-family: 'Orbitron', sans-serif;
            font-size: 0.75rem;
            padding: 10px 14px;
            border-radius: 2px;
            outline: none;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

            .name-input::placeholder {
                color: var(--text-dim);
            }

            .name-input:focus {
                box-shadow: 0 0 12px rgba(0,245,255,0.3);
            }

        /* ─── Side panel ─── */
        .side-panel {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* ─── Leaderboard ─── */
        .lb-list {
            list-style: none;
        }

        .lb-entry {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 0;
            border-bottom: 1px solid var(--border-dim);
            animation: lbIn 0.4s ease-out backwards;
        }

            .lb-entry:last-child {
                border-bottom: none;
            }
        @@keyframes lbIn {
            from {
                opacity: 0;
                transform: translateX(20px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .lb-rank {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.7rem;
            font-weight: 700;
            width: 24px;
            text-align: center;
            flex-shrink: 0;
        }

        .rank-1 {
            color: var(--neon-yellow);
            text-shadow: 0 0 8px var(--neon-yellow);
        }

        .rank-2 {
            color: #c0c0c0;
        }

        .rank-3 {
            color: #cd7f32;
        }

        .rank-other {
            color: var(--text-dim);
        }

        .lb-name {
            flex: 1;
            font-size: 0.75rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: #c0ccff;
        }

        .lb-score {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--neon-cyan);
            text-shadow: 0 0 6px var(--neon-cyan);
            flex-shrink: 0;
        }

        .lb-diff-badge {
            font-size: 0.55rem;
            padding: 2px 6px;
            border-radius: 2px;
            flex-shrink: 0;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .badge-easy {
            background: rgba(57,255,20,0.15);
            color: var(--neon-green);
            border: 1px solid rgba(57,255,20,0.3);
        }

        .badge-medium {
            background: rgba(255,230,0,0.15);
            color: var(--neon-yellow);
            border: 1px solid rgba(255,230,0,0.3);
        }

        .badge-hard {
            background: rgba(255,0,110,0.15);
            color: var(--neon-pink);
            border: 1px solid rgba(255,0,110,0.3);
        }

        /* ─── Instructions ─── */
        .instructions {
            font-size: 0.7rem;
            line-height: 1.7;
            color: var(--text-dim);
        }

            .instructions span {
                color: var(--neon-cyan);
            }

            .instructions .bomb-warn {
                color: var(--neon-pink);
            }

        /* ─── Pulse animation on new #1 ─── */
        @@keyframes rankPulse {
            0%, 100% {
                text-shadow: 0 0 8px var(--neon-yellow);
            }

            50% {
                text-shadow: 0 0 24px var(--neon-yellow), 0 0 48px var(--neon-yellow);
            }
        }

        .rank-1-animate {
            animation: rankPulse 1.5s ease-in-out infinite;
        }

        /* ─── Combo flash ─── */
        .combo-alert {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-family: 'Orbitron', sans-serif;
            font-size: clamp(1.5rem, 5vw, 3rem);
            font-weight: 900;
            pointer-events: none;
            z-index: 2000;
            text-align: center;
            animation: comboAnim 1.1s ease-out forwards;
        }
        @@keyframes comboAnim {
            0% {
                opacity: 1;
                transform: translate(-50%,-50%) scale(0.5);
            }

            30% {
                opacity: 1;
                transform: translate(-50%,-50%) scale(1.2);
            }

            70% {
                opacity: 1;
                transform: translate(-50%,-50%) scale(1.0);
            }

            100% {
                opacity: 0;
                transform: translate(-50%,-50%) scale(0.8) translateY(-40px);
            }
        }
    </style>
</head>
<body>
    <div class="wrapper">

        <!-- Header -->
        <header class="site-header">
            <h1>CYBER MOLE</h1>
            <p class="subtitle">Neon Whack-a-Mole // Arcade Edition</p>
        </header>

        <div class="layout">

            <!-- ── GAME AREA ── -->
            <div>
                <!-- HUD -->
                <div class="hud">
                    <div class="hud-item">
                        <span class="hud-label">Score</span>
                        <span class="hud-value" id="score-val">0</span>
                    </div>
                    <div class="hud-item">
                        <span class="hud-label">Time</span>
                        <span class="hud-value" id="timer-val">30</span>
                    </div>
                    <div class="hud-item">
                        <span class="hud-label">Combo</span>
                        <span class="hud-value" id="combo-val">x1</span>
                    </div>
                    <div class="hud-item">
                        <span class="hud-label">Misses</span>
                        <span class="hud-value" id="miss-val" style="color:#ff4466;text-shadow:0 0 10px #ff4466;">0</span>
                    </div>
                </div>

                <!-- Difficulty selector -->
                <div class="diff-group" id="diff-group">
                    <button class="diff-btn active-diff" data-diff="easy">Easy</button>
                    <button class="diff-btn" data-diff="medium">Medium</button>
                    <button class="diff-btn" data-diff="hard">Hard</button>
                </div>

                <!-- Game grid wrapper (for overlay positioning) -->
                <div style="position:relative;">
                    <div class="game-grid" id="game-grid"></div>

                    <!-- Overlay -->
                    <div class="overlay" id="overlay">
                        <div class="overlay-title" id="overlay-title">CYBER MOLE</div>
                        <div class="overlay-sub" id="overlay-sub">Select difficulty and jack in</div>
                        <div class="final-score hidden" id="final-score-wrap">
                            <div class="final-score" id="final-score-num">0</div>
                            <div class="final-label">Final Score</div>
                        </div>
                        <div class="name-row hidden" id="name-row">
                            <input class="name-input" id="player-name" type="text" maxlength="12" placeholder="ENTER NAME" autocomplete="off" />
                            <button class="btn btn-start" id="save-btn" style="flex:none;padding:10px 16px;">SAVE</button>
                        </div>
                        <div class="controls">
                            <button class="btn btn-start" id="start-btn">▶ START</button>
                        </div>
                    </div>
                </div>

                <!-- Controls below grid -->
                <div class="controls" style="margin-top:14px;">
                    <button class="btn btn-stop" id="stop-btn" disabled>■ ABORT</button>
                </div>
            </div>

            <!-- ── SIDE PANEL ── -->
            <div class="side-panel">

                <!-- Leaderboard -->
                <div class="panel">
                    <div class="panel-title">⬡ Leaderboard</div>
                    <ul class="lb-list" id="lb-list">
                        <li style="color:var(--text-dim);font-size:0.75rem;padding:8px 0;">No scores yet. Be the first!</li>
                    </ul>
                </div>

                <!-- Instructions -->
                <div class="panel">
                    <div class="panel-title">⬡ How to play</div>
                    <div class="instructions">
                        <p>Moles pop from the holes — <span>click them fast</span> before they vanish.</p>
                        <br />
                        <p><span>Combo multiplier</span> grows with each consecutive hit. Miss one and it resets to x1.</p>
                        <br />
                        <p><span class="bomb-warn">Pink moles = BOMBS.</span> Clicking a bomb deducts 30 pts and resets your combo!</p>
                        <br />
                        <p>Game lasts <span>30 seconds</span>. Top scores save to your local leaderboard.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ── CONFIG ──────────────────────────────────────────────────────────────
        const DIFFS = {
            easy:   { moleTime: 1400, spawnRate: 900,  bombChance: 0.08, duration: 30, pointsPerHit: 10 },
            medium: { moleTime: 900,  spawnRate: 650,  bombChance: 0.15, duration: 30, pointsPerHit: 15 },
            hard:   { moleTime: 580,  spawnRate: 420,  bombChance: 0.22, duration: 30, pointsPerHit: 20 },
        };
        const HOLES = 12;
        const MAX_LB = 10;
        const LS_KEY = 'cybermole_lb_v3';

        // ── STATE ────────────────────────────────────────────────────────────────
        let score = 0, combo = 1, misses = 0, timeLeft = 30;
        let activeDiff = 'easy';
        let gameRunning = false;
        let spawnInterval = null, timerInterval = null;
        let activeMoles = new Set();
        let moleTimers = {};

        // ── DOM REFS ─────────────────────────────────────────────────────────────
        const grid        = document.getElementById('game-grid');
        const overlay     = document.getElementById('overlay');
        const overlayT    = document.getElementById('overlay-title');
        const overlaySub  = document.getElementById('overlay-sub');
        const finalWrap   = document.getElementById('final-score-wrap');
        const finalNum    = document.getElementById('final-score-num');
        const nameRow     = document.getElementById('name-row');
        const nameInput   = document.getElementById('player-name');
        const startBtn    = document.getElementById('start-btn');
        const stopBtn     = document.getElementById('stop-btn');
        const saveBtn     = document.getElementById('save-btn');
        const scoreEl     = document.getElementById('score-val');
        const timerEl     = document.getElementById('timer-val');
        const comboEl     = document.getElementById('combo-val');
        const missEl      = document.getElementById('miss-val');
        const lbList      = document.getElementById('lb-list');
        const diffGroup   = document.getElementById('diff-group');

        // ── BUILD GRID ────────────────────────────────────────────────────────────
        function buildGrid() {
            grid.innerHTML = '';
            for (let i = 0; i < HOLES; i++) {
                const hole = document.createElement('div');
                hole.className = 'hole';
                hole.dataset.index = i;
                hole.innerHTML = `<div class="mole"><svg class="mole-svg" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                    <!-- Mole body -->
                    <ellipse cx="40" cy="52" rx="26" ry="20" fill="#1a0a2e"/>
                    <!-- Face -->
                    <ellipse cx="40" cy="38" rx="22" ry="22" fill="#2a1040"/>
                    <!-- Eyes -->
                    <circle cx="32" cy="34" r="5" fill="#0a0a0a"/>
                    <circle cx="48" cy="34" r="5" fill="#0a0a0a"/>
                    <!-- Eye glow (normal = cyan) -->
                    <circle cx="32" cy="34" r="3" fill="#00f5ff" opacity="0.9" class="eye-glow"/>
                    <circle cx="48" cy="34" r="3" fill="#00f5ff" opacity="0.9" class="eye-glow"/>
                    <!-- Nose -->
                    <ellipse cx="40" cy="42" rx="5" ry="3.5" fill="#ff006e" opacity="0.8"/>
                    <!-- Mouth -->
                    <path d="M34 48 Q40 54 46 48" stroke="#00f5ff" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.6" class="mole-mouth"/>
                    <!-- Ears -->
                    <ellipse cx="20" cy="26" rx="7" ry="9" fill="#2a1040"/>
                    <ellipse cx="60" cy="26" rx="7" ry="9" fill="#2a1040"/>
                    <ellipse cx="20" cy="26" rx="4" ry="6" fill="#3d1060" opacity="0.7"/>
                    <ellipse cx="60" cy="26" rx="4" ry="6" fill="#3d1060" opacity="0.7"/>
                    <!-- Visor line -->
                    <line x1="18" y1="36" x2="28" y2="36" stroke="#00f5ff" stroke-width="1" opacity="0.4"/>
                    <line x1="52" y1="36" x2="62" y2="36" stroke="#00f5ff" stroke-width="1" opacity="0.4"/>
                </svg></div>`;
                hole.addEventListener('click', () => onHoleClick(hole, i));
                grid.appendChild(hole);
            }
        }

        function getBombSVG() {
            return `<svg class="mole-svg" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                <!-- Bomb mole body -->
                <ellipse cx="40" cy="52" rx="26" ry="20" fill="#1a0010"/>
                <ellipse cx="40" cy="38" rx="22" ry="22" fill="#2a0020"/>
                <!-- Eyes - pink/red -->
                <circle cx="32" cy="34" r="5" fill="#0a0a0a"/>
                <circle cx="48" cy="34" r="5" fill="#0a0a0a"/>
                <circle cx="32" cy="34" r="3" fill="#ff006e" opacity="0.9"/>
                <circle cx="48" cy="34" r="3" fill="#ff006e" opacity="0.9"/>
                <!-- Nose -->
                <ellipse cx="40" cy="42" rx="5" ry="3.5" fill="#ff006e"/>
                <!-- Skull mouth -->
                <path d="M33 48 Q40 56 47 48" stroke="#ff006e" stroke-width="2" fill="none" stroke-linecap="round"/>
                <line x1="37" y1="50" x2="37" y2="54" stroke="#ff006e" stroke-width="1.5"/>
                <line x1="40" y1="50" x2="40" y2="54" stroke="#ff006e" stroke-width="1.5"/>
                <line x1="43" y1="50" x2="43" y2="54" stroke="#ff006e" stroke-width="1.5"/>
                <!-- Ears -->
                <ellipse cx="20" cy="26" rx="7" ry="9" fill="#2a0020"/>
                <ellipse cx="60" cy="26" rx="7" ry="9" fill="#2a0020"/>
                <!-- X marks -->
                <line x1="14" y1="20" x2="26" y2="32" stroke="#ff006e" stroke-width="1.5" opacity="0.6"/>
                <line x1="26" y1="20" x2="14" y2="32" stroke="#ff006e" stroke-width="1.5" opacity="0.6"/>
                <!-- Warning lines -->
                <line x1="18" y1="36" x2="28" y2="36" stroke="#ff006e" stroke-width="1" opacity="0.5"/>
                <line x1="52" y1="36" x2="62" y2="36" stroke="#ff006e" stroke-width="1" opacity="0.5"/>
            </svg>`;
        }

        // ── GAME LOGIC ────────────────────────────────────────────────────────────
        function startGame() {
            score = 0; combo = 1; misses = 0;
            const cfg = DIFFS[activeDiff];
            timeLeft = cfg.duration;
            updateHUD();
            gameRunning = true;
            overlay.classList.add('hidden');
            stopBtn.disabled = false;
            startBtn.disabled = true;
            diffGroup.querySelectorAll('.diff-btn').forEach(b => b.disabled = true);

            // Reset all holes
            grid.querySelectorAll('.hole').forEach(h => {
                h.classList.remove('active','bomb','whacked');
                h.dataset.bomb = '';
            });
            activeMoles.clear();
            Object.values(moleTimers).forEach(clearTimeout);
            moleTimers = {};

            spawnInterval = setInterval(spawnMole, cfg.spawnRate);
            timerInterval = setInterval(tickTimer, 1000);
        }

        function spawnMole() {
            if (!gameRunning) return;
            const holes = [...grid.querySelectorAll('.hole:not(.active)')];
            if (holes.length === 0) return;
            const hole = holes[Math.floor(Math.random() * holes.length)];
            const idx  = parseInt(hole.dataset.index);
            const cfg  = DIFFS[activeDiff];
            const isBomb = Math.random() < cfg.bombChance;

            hole.dataset.bomb = isBomb ? '1' : '';
            if (isBomb) {
                hole.classList.add('bomb');
                hole.querySelector('.mole').innerHTML = getBombSVG();
            }
            hole.classList.add('active');
            activeMoles.add(idx);

            moleTimers[idx] = setTimeout(() => {
                if (hole.classList.contains('active') && !hole.classList.contains('whacked')) {
                    hideMole(hole, idx, true); // missed
                }
            }, cfg.moleTime);
        }

        function hideMole(hole, idx, missed) {
            if (missed && !hole.dataset.bomb) {
                misses++;
                combo = 1;
                updateHUD();
            }
            hole.classList.remove('active','bomb','whacked');
            resetMoleFace(hole);
            activeMoles.delete(idx);
            clearTimeout(moleTimers[idx]);
        }

        function resetMoleFace(hole) {
            hole.querySelector('.mole').innerHTML = `<svg class="mole-svg" viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="40" cy="52" rx="26" ry="20" fill="#1a0a2e"/>
                <ellipse cx="40" cy="38" rx="22" ry="22" fill="#2a1040"/>
                <circle cx="32" cy="34" r="5" fill="#0a0a0a"/>
                <circle cx="48" cy="34" r="5" fill="#0a0a0a"/>
                <circle cx="32" cy="34" r="3" fill="#00f5ff" opacity="0.9" class="eye-glow"/>
                <circle cx="48" cy="34" r="3" fill="#00f5ff" opacity="0.9" class="eye-glow"/>
                <ellipse cx="40" cy="42" rx="5" ry="3.5" fill="#ff006e" opacity="0.8"/>
                <path d="M34 48 Q40 54 46 48" stroke="#00f5ff" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.6"/>
                <ellipse cx="20" cy="26" rx="7" ry="9" fill="#2a1040"/>
                <ellipse cx="60" cy="26" rx="7" ry="9" fill="#2a1040"/>
                <ellipse cx="20" cy="26" rx="4" ry="6" fill="#3d1060" opacity="0.7"/>
                <ellipse cx="60" cy="26" rx="4" ry="6" fill="#3d1060" opacity="0.7"/>
                <line x1="18" y1="36" x2="28" y2="36" stroke="#00f5ff" stroke-width="1" opacity="0.4"/>
                <line x1="52" y1="36" x2="62" y2="36" stroke="#00f5ff" stroke-width="1" opacity="0.4"/>
            </svg>`;
        }

        function onHoleClick(hole, idx) {
            if (!gameRunning || !hole.classList.contains('active')) return;
            const isBomb = hole.dataset.bomb === '1';
            clearTimeout(moleTimers[idx]);

            // Animate out
            hole.classList.add('whacked');

            if (isBomb) {
                score = Math.max(0, score - 30);
                combo = 1;
                spawnFlash(hole, true);
                spawnScorePop(hole, '-30', '#ff006e');
            } else {
                const pts = DIFFS[activeDiff].pointsPerHit * combo;
                score += pts;
                combo++;
                spawnFlash(hole, false);
                spawnScorePop(hole, `+${pts}`, combo > 2 ? '#ffe600' : '#00f5ff');
                if (combo > 2 && combo % 3 === 1) showComboAlert(combo - 1);
            }

            updateHUD();

            setTimeout(() => {
                hideMole(hole, idx, false);
            }, 200);
        }

        function tickTimer() {
            timeLeft--;
            timerEl.textContent = timeLeft;
            if (timeLeft <= 5) {
                timerEl.style.animation = 'flicker 0.5s infinite';
                timerEl.style.color = '#ff006e';
            }
            if (timeLeft <= 0) endGame();
        }

        function endGame() {
            gameRunning = false;
            clearInterval(spawnInterval);
            clearInterval(timerInterval);

            // Hide all active moles
            grid.querySelectorAll('.hole.active').forEach(h => {
                h.classList.remove('active','bomb','whacked');
                resetMoleFace(h);
            });
            activeMoles.clear();

            stopBtn.disabled = true;
            startBtn.disabled = false;
            diffGroup.querySelectorAll('.diff-btn').forEach(b => b.disabled = false);

            // Show end overlay
            overlayT.textContent = score > 0 ? 'GAME OVER' : 'DISCONNECTED';
            overlaySub.textContent = `Difficulty: ${activeDiff.toUpperCase()} • Misses: ${misses}`;
            finalNum.textContent = score;
            finalWrap.classList.remove('hidden');
            nameRow.classList.remove('hidden');
            nameInput.value = '';
            overlay.classList.remove('hidden');
            timerEl.style.animation = '';
            timerEl.style.color = '';
        }

        function stopGame() {
            if (!gameRunning) return;
            gameRunning = false;
            clearInterval(spawnInterval);
            clearInterval(timerInterval);
            grid.querySelectorAll('.hole.active').forEach(h => {
                h.classList.remove('active','bomb','whacked');
                resetMoleFace(h);
            });
            activeMoles.clear();
            stopBtn.disabled = true;
            startBtn.disabled = false;
            diffGroup.querySelectorAll('.diff-btn').forEach(b => b.disabled = false);
            overlayT.textContent = 'ABORTED';
            overlaySub.textContent = 'Jack out detected. Try again.';
            finalWrap.classList.add('hidden');
            nameRow.classList.add('hidden');
            overlay.classList.remove('hidden');
            timerEl.style.animation = '';
            timerEl.style.color = '';
        }

        // ── HUD ───────────────────────────────────────────────────────────────────
        function updateHUD() {
            scoreEl.textContent = score;
            timerEl.textContent = timeLeft;
            comboEl.textContent = `x${combo}`;
            missEl.textContent  = misses;
        }

        // ── VISUAL FX ─────────────────────────────────────────────────────────────
        function spawnFlash(hole, isBomb) {
            const flash = document.createElement('div');
            flash.className = 'hit-flash' + (isBomb ? ' bomb-flash' : '');
            hole.appendChild(flash);
            flash.addEventListener('animationend', () => flash.remove());
        }

        function spawnScorePop(hole, text, color) {
            const rect = hole.getBoundingClientRect();
            const el = document.createElement('div');
            el.className = 'score-pop';
            el.textContent = text;
            el.style.color = color;
            el.style.left = (rect.left + rect.width / 2 - 20) + 'px';
            el.style.top  = (rect.top + window.scrollY) + 'px';
            document.body.appendChild(el);
            el.addEventListener('animationend', () => el.remove());
        }

        function showComboAlert(comboCount) {
            const msgs = ['DOUBLE!','TRIPLE!','QUAD!','ULTRA!','MEGA!','GODLIKE!'];
            const colors = ['#00f5ff','#ffe600','#39ff14','#bf00ff','#ff006e','#ffffff'];
            const i = Math.min(comboCount - 2, msgs.length - 1);
            const el = document.createElement('div');
            el.className = 'combo-alert';
            el.textContent = msgs[i];
            el.style.color = colors[i];
            el.style.textShadow = `0 0 20px ${colors[i]}, 0 0 50px ${colors[i]}`;
            document.body.appendChild(el);
            el.addEventListener('animationend', () => el.remove());
        }

        // ── LEADERBOARD ───────────────────────────────────────────────────────────
        function loadLB() {
            try { return JSON.parse(localStorage.getItem(LS_KEY)) || []; }
            catch { return []; }
        }
        function saveLBEntry(name, sc, diff) {
            let lb = loadLB();
            lb.push({ name: name.toUpperCase().slice(0,12) || 'ANONYMOUS', score: sc, diff });
            lb.sort((a,b) => b.score - a.score);
            lb = lb.slice(0, MAX_LB);
            localStorage.setItem(LS_KEY, JSON.stringify(lb));
            renderLB(lb);
        }
        function renderLB(lb) {
            if (!lb || lb.length === 0) {
                lbList.innerHTML = '<li style="color:var(--text-dim);font-size:0.75rem;padding:8px 0;">No scores yet. Be the first!</li>';
                return;
            }
            lbList.innerHTML = lb.map((e, i) => {
                const rankClass = i === 0 ? 'rank-1 rank-1-animate' : i === 1 ? 'rank-2' : i === 2 ? 'rank-3' : 'rank-other';
                const rankLabel = i === 0 ? '①' : i === 1 ? '②' : i === 2 ? '③' : `${i+1}.`;
                const badgeClass = e.diff === 'hard' ? 'badge-hard' : e.diff === 'medium' ? 'badge-medium' : 'badge-easy';
                return `<li class="lb-entry" style="animation-delay:${i*0.05}s">
                    <span class="lb-rank ${rankClass}">${rankLabel}</span>
                    <span class="lb-name">${e.name}</span>
                    <span class="lb-diff-badge ${badgeClass}">${e.diff}</span>
                    <span class="lb-score">${e.score}</span>
                </li>`;
            }).join('');
        }

        // ── EVENTS ────────────────────────────────────────────────────────────────
        startBtn.addEventListener('click', () => {
            finalWrap.classList.add('hidden');
            nameRow.classList.add('hidden');
            buildGrid();
            startGame();
        });
        stopBtn.addEventListener('click', stopGame);
        saveBtn.addEventListener('click', () => {
            const name = nameInput.value.trim() || 'ANONYMOUS';
            saveLBEntry(name, score, activeDiff);
            nameRow.classList.add('hidden');
            saveBtn.textContent = '✓ SAVED';
            saveBtn.disabled = true;
        });
        diffGroup.querySelectorAll('.diff-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                diffGroup.querySelectorAll('.diff-btn').forEach(b => b.classList.remove('active-diff'));
                btn.classList.add('active-diff');
                activeDiff = btn.dataset.diff;
            });
        });
        nameInput.addEventListener('keydown', e => {
            if (e.key === 'Enter') saveBtn.click();
        });

        // ── INIT ──────────────────────────────────────────────────────────────────
        buildGrid();
        renderLB(loadLB());
    </script>
</body>
</html>
